// Prisma schema for Cloudflare D1 (SQLite)
// Mirrors the existing schema.sql tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Demo {
  id          String     @id @default(uuid())
  title       String
  description String
  url         String?
  imageUrl    String
  fileType    String?
  filePath    String?
  isActive    Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  features    Feature[]
  files       DemoFile[]
}

model Feature {
  id        String   @id @default(uuid())
  name      String
  demoId    String
  isEnabled Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  demo      Demo     @relation(fields: [demoId], references: [id])

  @@index([demoId])
}

model DemoFile {
  id        String   @id @default(uuid())
  demoId    String
  name      String
  path      String
  content   Bytes
  fileType  String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  demo      Demo     @relation(fields: [demoId], references: [id])

  @@index([demoId])
}

model Project {
  id          String   @id
  name        String
  description String
  githubLink  String
  owner       String
  ownerName   String
  stars       Int
  language    String
  updatedAt   DateTime @default(now()) @updatedAt
  private     Boolean
}

model Organization {
  name    String @id
  mission String
  link    String
  logo    String
}

model Language {
  id   String @id
  name String
  type String // "core" or "other"
}

model Service {
  id          String @id
  title       String
  category    String
  description String
  techs       String // Store techs as a JSON or comma-separated string
  iconName    String
  colorClass  String
}
