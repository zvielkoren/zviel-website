{
  "name": "zviel-websit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev",
    "pages:build": "opennextjs-cloudflare build && mv .open-next/worker.js .open-next/_worker.js && cp -r .open-next/assets/* .open-next/ && node scripts/patch-worker.js",
    "start": "next start",
    "lint": "eslint .",
    "preview": "pnpm run pages:build && wrangler pages dev .open-next",
    "wrangler": "echo",
    "deploy": "pnpm run pages:build && wrangler pages deploy .open-next",
    "upload": "pnpm run pages:build && wrangler pages deploy .open-next",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@emailjs/browser": "4.4.1",
    "@heroui/react": "3.0.4",
    "@heroui/styles": "3.0.4",
    "framer-motion": "12.38.0",
    "jose": "6.2.3",
    "jszip": "3.10.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "styled-components": "6.4.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "create-cloudflare": "2.68.1",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "postcss": "8.5.14",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "wrangler": "4.98.0"
  },
  "browser": {
    "crypto": false,
    "stream": false
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "workerd"
    ]
  }
}