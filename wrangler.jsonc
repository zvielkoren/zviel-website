{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "zviel-websit",
	"compatibility_date": "2026-06-04",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"pages_build_output_dir": ".open-next",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "zviel-website-db",
			"database_id": "9b4a91e8-b258-4a5c-b672-b863d1207550"
		}
	],
	"vars": {
		"NODE_VERSION": "24.0.0",
		"ADMIN_USERNAME": "admin",
		"HOST_VERSIONS_API": "https://zviel.com/api/versions"
	}
}