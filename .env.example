# GitHub API
GITHUB_TOKEN=your_github_personal_access_token

# EmailJS (public — safe to expose to the browser)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_USER_ID=your_emailjs_public_key

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
JWT_SECRET=your_super_secret_jwt_key

# Versions API (optional, defaults to https://zvielkoren.com/api/versions)
HOST_VERSIONS_API=https://zviel.com/api/versions
